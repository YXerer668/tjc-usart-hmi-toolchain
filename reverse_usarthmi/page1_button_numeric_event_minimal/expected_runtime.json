{
  "name": "page1_button_numeric_event_minimal_live_expectations",
  "select_page": 0,
  "page_id": 0,
  "restore_page": 1,
  "expectations": [
    {
      "target": "numval.val",
      "expected": 3,
      "expected_kind": "number",
      "attempts": 3
    },
    {
      "target": "inc0.txt",
      "expected": "INC",
      "expected_kind": "string",
      "attempts": 3
    }
  ],
  "steps": [
    {
      "label": "press inc0 once",
      "command": "click inc0,1",
      "delay_ms": 120
    },
    {
      "label": "release inc0 once",
      "command": "click inc0,0",
      "delay_ms": 120
    },
    {
      "label": "numval incremented once",
      "command": "get numval.val",
      "expected_kind": "number",
      "expected": 4,
      "attempts": 3
    },
    {
      "label": "press inc0 twice",
      "command": "click inc0,1",
      "delay_ms": 120
    },
    {
      "label": "release inc0 twice",
      "command": "click inc0,0",
      "delay_ms": 120
    },
    {
      "label": "numval incremented twice",
      "command": "get numval.val",
      "expected_kind": "number",
      "expected": 5,
      "attempts": 3
    }
  ]
}
